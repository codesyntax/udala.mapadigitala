<html xmlns="http://www.w3.org/1999/xhtml"
      xmlns:i18n="http://xml.zope.org/namespaces/i18n"
      xmlns:metal="http://xml.zope.org/namespaces/metal"
      xmlns:tal="http://xml.zope.org/namespaces/tal"
      metal:use-macro="context/main_template/macros/master"
      i18n:domain="udala.mapadigitala"
>
  <body>


    <metal:content-core fill-slot="content-core">
      <metal:block define-macro="content-core">

        <geoeuskadi-map class="mapa_component"
                        id="Mi-Mapa"
                        height="100%"
                        lang="EU"
                        width="100%"
                        xmax="564360"
                        xmin="555884"
                        xml:lang="EU"
                        ymax="4772585"
                        ymin="4785736"
                        zoom="12"
        >
          <geoeuskadi-header logo_url="https://www.azpeitia.eus/"
                             name="geoAzpeitia"
                             name_eus="geoAzpeitia"
          >
          </geoeuskadi-header>
          <geoeuskadi-widgets mode="only">
            <tal:widget repeat="widget context/shown_widgets">
              <geoeuskadi-widget id="CapasBase"
                                 tal:attributes="
                                   id widget;
                                 "
              ></geoeuskadi-widget>
            </tal:widget>
          </geoeuskadi-widgets>
          <geoeuskadi-layers mode="only">
            <geoeuskadi-layer id="Ingurua"
                              checked="checked"
                              label="Boundary"
                              remove=""
                              src="https://www.azpeitia.eus/azpeitia.kml"
                              type="KML"
                              tal:attributes="
                                src string:${context/absolute_url}/@@download/bounding_xml;
                              "
                              i18n:attributes="label"
            ></geoeuskadi-layer>
            <tal:layer repeat="layer context/shown_layers">
              <geoeuskadi-layer id="CapasBase"
                                tal:attributes="
                                  id layer;
                                "
              ></geoeuskadi-layer>
            </tal:layer>
          </geoeuskadi-layers>
        </geoeuskadi-map>
        <script src="https://www.geo.euskadi.eus/bisorea/web-component/config/geoEuskadi.js"
                type="text/javascript"
        ></script>


      </metal:block>
    </metal:content-core>
  </body>
</html>
